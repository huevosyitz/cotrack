  "version": "0.2.0",
  "configurations": [
    {
      "name": "cotrack wasm",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": ["-d", "chrome", "--dart-define-from-file=.env", "--wasm"],
      "flutterMode": "debug"
    },
    {
      "name": "cotrack default",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": ["-d", "chrome", "--dart-define-from-file=.env"],
      "flutterMode": "debug"
    },
    {
      "name": "cotrack (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "cotrack (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    }
  ]
}
